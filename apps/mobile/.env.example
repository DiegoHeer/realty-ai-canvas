# Base URL of the listings API. Leave empty to use the bundled mock data.
# Staging (Realty Alerts API): https://api-staging.realty-ai.nl
EXPO_PUBLIC_API_URL=

# Force bundled mock data even when an API URL is set ("true" | "false").
# Defaults to mocks whenever EXPO_PUBLIC_API_URL is empty.
EXPO_PUBLIC_USE_MOCKS=
