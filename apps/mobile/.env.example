# Base URL of the listings API (required — the app fetches all data from here).
# Staging (Realty Alerts API): https://api-staging.realty-ai.nl
EXPO_PUBLIC_API_URL=https://api-staging.realty-ai.nl

# Use the real allauth auth backend (signup/login/email verification by code)
# instead of the mock auth path ("true" | "false", default false when unset).
# When off, auth is mocked locally and no real account/email is created.
EXPO_PUBLIC_AUTH_ENABLED=true

# Google OAuth client ids for "Continue with Google" (real auth mode only;
# leave empty to hide the button on that platform). The Web id must equal the
# backend's GOOGLE_OAUTH_CLIENT_ID; the web origin and <origin>/auth/callback
# must be authorized for it in the Google console. The Android/iOS ids are the
# platform's installed-app clients (no secret); the backend must also accept
# them. See docs/oauth-social-login.md.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Anonymous, cookieless usage analytics (self-hosted Plausible). On by default;
# set ENABLED=false for local dev/e2e so test traffic never reaches the live
# dashboard. URL is the Plausible base URL, DOMAIN is the site in the dashboard.
EXPO_PUBLIC_PLAUSIBLE_ENABLED=true
EXPO_PUBLIC_PLAUSIBLE_URL=https://plausible.realty-ai.nl
EXPO_PUBLIC_PLAUSIBLE_DOMAIN=realty-ai-canvas
