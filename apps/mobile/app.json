{
  "expo": {
    "name": "Huismus",
    "slug": "huismus",
    "owner": "huismus",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "huismus",
      "com.googleusercontent.apps.751654542404-7eo1jn9ram6adtdecinc9bmfk7a791f5",
      "com.googleusercontent.apps.751654542404-066oobvgungucgk2v8diuoedas0atha2"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.fastvibes.huismus",
      "associatedDomains": [
        "applinks:huismusapp.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.fastvibes.huismus",
      "intentFilters": [
        {
          "autoVerify": true,
          "action": "VIEW",
          "data": {
            "scheme": "https",
            "host": "huismusapp.com"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-localization",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "d5a8e7ed-293c-4105-ba05-1ecc6cb0a5ec"
      }
    }
  }
}
